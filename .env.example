# ─── Supabase (required for cloud sync / auth) ────────────────────────────────
# Find these in your Supabase project: Settings → API
#
# The anon key is intentionally public — it is designed for client-side use.
# Security is enforced by Row Level Security (RLS) policies on the database.
# The SERVICE ROLE key must never be committed or exposed.
#
# Copy this file to .env.local and fill in your values.
# .env.local is in .gitignore and will never be committed to git.
#
# The app works fully offline without these vars — cloud sync is simply disabled.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
